{
  "manifest_version": 3,
  "name": "TikTok Maps Saver",
  "version": "1.0",
  "description": "Automatically captures and saves locations mentioned in TikToks to Google Maps.",
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://tiktok.com/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.tiktok.com/*",
        "https://tiktok.com/*"
      ],
      "js": ["content-script.js"]
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}
